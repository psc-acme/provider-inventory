{
    "name": "psc-acme/provider-inventory",
    "description": "Package provider-inventory for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProviderInventory\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "illuminate/database": "^11.0",
        "symfony/string": "^7.0",
        "guzzlehttp/psr7": "^2.0",
        "league/flysystem": "^3.0",
        "predis/predis": "^2.0",
        "psc-acme/loader-cart": "^1.0",
        "psc-acme/validator-product": "^1.0",
        "psc-acme/sdk-inventory": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.0",
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan-symfony": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}